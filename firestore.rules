rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Produits : lecture publique (boutique), écriture réservée aux comptes
    // connectés via Firebase Authentication (vos comptes admin).
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
